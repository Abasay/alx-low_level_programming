#include <stdio.h>
/**
 * main - body of function
 * Return: returns 0 when successful
 */
int main(void)
{
        char i;

        i = 'a';
        while (i <= 'z')
        {
		if ((i != 'e') || (i != 'q'))
		{
			putchar(i);
		}
                i++;
        }
        putchar('\n');
        return (0);
}
